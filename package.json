{
  "name": "jieluxia",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "cf:build": "opennextjs-cloudflare build && node -e \"require('fs').copyFileSync('.open-next/worker.js','.open-next/_worker.js')\" && node scripts/gen-routes.mjs",
    "cf:deploy": "opennextjs-cloudflare build && node -e \"require('fs').copyFileSync('.open-next/worker.js','.open-next/_worker.js')\" && node scripts/gen-routes.mjs && wrangler pages deploy .open-next",
    "worker:deploy": "wrangler deploy --config wrangler.worker.toml"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "nanoid": "^5.1.11",
    "next": "^15.5.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.93.0"
  }
}
